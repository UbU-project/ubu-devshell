{
  "schema_version": "ubu.devshell.fixture_demo.stochastic_rollout_cases.v1",
  "public_safe": true,
  "notes": "Offline fixed-seed D12 coverage for API-reachable stochastic rollout, rollout re-ranking, correlation effects, and not_estimated. Requests are posted only to the loopback orchestrator API.",
  "cases": [
    {
      "name": "stochastic-rerank",
      "request": {
        "schema_version": "planning-kernel-contract/0.1",
        "request_id": "d12-stochastic-rerank",
        "mode": "fresh_generation",
        "rng_seed": 42,
        "compute_budget": {
          "n_rollouts": 1000,
          "top_k": 3
        },
        "time_window": {
          "start": 0,
          "end": 10
        },
        "topological_order": [
          "task-a",
          "task-b",
          "task-c"
        ],
        "tasks": [
          {
            "id": "task-a",
            "duration": 1,
            "duration_estimate": {
              "type": "shifted_lognormal_p95",
              "min_seconds": 0,
              "mode_seconds": 1,
              "p95_seconds": 4
            }
          },
          {
            "id": "task-b",
            "duration": 1,
            "duration_estimate": {
              "type": "shifted_lognormal_p95",
              "min_seconds": 0,
              "mode_seconds": 1,
              "p95_seconds": 4
            },
            "depends_on": [
              "task-a"
            ]
          },
          {
            "id": "task-c",
            "duration": 1,
            "duration_estimate": {
              "type": "shifted_lognormal_p95",
              "min_seconds": 0,
              "mode_seconds": 1,
              "p95_seconds": 4
            },
            "depends_on": [
              "task-b"
            ]
          }
        ]
      },
      "expected": {
        "candidate_count": 16,
        "finalist_count": 3
      }
    },
